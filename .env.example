# Sourcing
KEYWORDS=python,typescript
WORK_MODE=remote
HEADLESS=true

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=looking_for_job
DB_PASSWORD=looking_for_job

# Redis / Sidekiq
REDIS_URL=redis://127.0.0.1:6379
SIDEKIQ_WEB_USERNAME=admin
SIDEKIQ_WEB_PASSWORD=secret

# Rails
RAILS_MAX_THREADS=5
PORT=3000
RAILS_LOG_LEVEL=info

# LLM
LLM_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
# OPENAI_API_KEY=   # alternative to LLM_API_KEY
# OPENAI_MODEL=     # alternative to LLM_MODEL

# Storage (RustFS / S3-compatible)
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_REGION=us-east-1
RUSTFS_BUCKET=looking-for-job-active-storage
RUSTFS_ENDPOINT=http://127.0.0.1:9000

# Providers
CADREMPLOI_REQUIRE_SESSION=false
